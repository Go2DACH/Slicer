{
  "name": "slicer-3d-scan-viewer",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Client-side 3D scan viewer, measurement and 2D floor-plan (BIM) drawing tool for GitHub Pages",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "gen:samples": "node scripts/genSamples.mjs",
    "test:unit": "node --experimental-strip-types scripts/unit.test.mts",
    "test:smoke": "node scripts/smoke.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.0",
    "@react-three/fiber": "^8.17.10",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "three-bvh-csg": "^0.0.16",
    "three-mesh-bvh": "^0.8.3",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.19.21",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
